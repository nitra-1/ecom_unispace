# ─────────────────────────────────────────────
#  Appointment Booking Module – Backend .env
# ─────────────────────────────────────────────

# Server
PORT=5050
NODE_ENV=development

# ── Database ──────────────────────────────────
# Set DB_CLIENT to "sqlite3" for local dev or "pg" for PostgreSQL in production.
DB_CLIENT=sqlite3

# SQLite (used when DB_CLIENT=sqlite3)
DB_FILENAME=./database/appointments.sqlite

# PostgreSQL (used when DB_CLIENT=pg)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appointments_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── JWT ───────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Email (Nodemailer) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Aparna Unispace <noreply@aparna.com>

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Slot Generation ───────────────────────────
# Reminder intervals in hours (comma-separated)
REMINDER_INTERVALS_HOURS=24,2
