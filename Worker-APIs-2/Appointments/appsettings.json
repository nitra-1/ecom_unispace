{
  // ==========================================================
  // appsettings.json – Appointment Booking Service Configuration
  //
  // IMPORTANT: Replace every <placeholder> before deploying.
  //
  // Sensitive values (JwtSettings:Secret, connection strings)
  // should be stored in environment variables or a secrets
  // manager (e.g. Azure Key Vault) in production.
  // ==========================================================

  "ConnectionStrings": {
    // EF6 Database-First connection string for the Appointment database.
    // To re-scaffold models after a schema change, update this value and run:
    //   dotnet ef dbcontext scaffold "Name=AppointmentDb" EntityFramework.SqlServer ...
    "AppointmentDb": "Server=<SQL_SERVER_HOST>;Database=AparnaAppointmentDb;User Id=<DB_USER>;Password=<DB_PASSWORD>;TrustServerCertificate=True;"
  },

  "JwtSettings": {
    // MUST match the secret used by the IDServer (Worker-APIs-1/IDServer)
    // so tokens issued by the identity service are accepted here.
    "Secret": "<REPLACE_WITH_JWT_SECRET_KEY_AT_LEAST_32_CHARS>",
    "Issuer": "AparnaPlatform",
    "Audience": "AparnaPlatform",
    // Access token lifetime in minutes
    "AccessTokenExpiryMinutes": 60,
    // Refresh token lifetime in days
    "RefreshTokenExpiryDays": 30
  },

  "ApiGateway": {
    // Base URL of the main Aparna API used for:
    //  1. Posting audit logs to POST /api/Log
    //  2. Forwarding notification saves to POST /api/Notification/SaveNotifications
    "BaseUrl": "https://api.aparna.hashtechy.space/api/"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
